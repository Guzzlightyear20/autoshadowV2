# ─────────────────────────────────────────────────────────────────────────────
# AutoShadow AI — Variables de entorno
# Copia este archivo como .env.local y completa los valores.
# ─────────────────────────────────────────────────────────────────────────────

# Tu API Key de Google Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# ── Modo proxy (desarrollo local seguro) ─────────────────────────────────────
# Cuando es "true", el frontend llama al proxy Express en lugar de a Gemini
# directamente, manteniendo la API key fuera del bundle del navegador.
#
# true  → usa el servidor proxy en server/index.ts (recomendado para producción)
# false → llama a Gemini directamente desde el navegador (Google AI Studio)
#
VITE_USE_PROXY=true

# Puerto del servidor proxy (por defecto 3001)
# SERVER_PORT=3001
